# CapCurve Environment Variables
# Copy this to .env and fill in values — never commit .env

POSTGRES_USER=capcurve
POSTGRES_PASSWORD=capcurve_dev
POSTGRES_DB=capcurve_development

DATABASE_URL=postgres://capcurve:capcurve_dev@db:5432/capcurve_development?sslmode=disable

PORT=8080
ENV=development
JWT_SECRET=dev_secret_change_in_production

# MLB Stats API (free, no key required for most endpoints)
MLB_API_BASE_URL=https://statsapi.mlb.com/api/v1

# Frontend
VITE_API_URL=http://localhost:8080/api/v1
